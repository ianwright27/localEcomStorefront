{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://wrightcommerce.onlinewebshop.net/public/api/:path*"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "http://wrightcommerce.onlinewebshop.net/public/webhooks/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}